# Copy to .env if your deployment platform does not manage environment variables.
# The app runs without these in mock mode.

# Server
PORT=3000
HOST=127.0.0.1

# Google Places API (New). Keep this secret server-side.
GOOGLE_MAPS_API_KEY=

# Optional: set to 1 to use live Google Places when GOOGLE_MAPS_API_KEY exists.
USE_GOOGLE_PLACES=0

# Resource source mode:
# free = trusted list + SQLite cache + optional OpenStreetMap refresh
# auto = free path first, Google fallback when configured
# google = Google Places only
RESOURCE_SOURCE=free

# Optional free refresh through public OSM services. Keep modest and cache results.
USE_OSM_OVERPASS=0
CACHE_TTL_DAYS=7
APP_USER_AGENT=StrokeResourceFinder/0.1 (+https://example.org/contact)

# Optional shared classroom database. Use these on Vercel so every student writes
# to the same Supabase Postgres table.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set to 1 to call scripts/adi_sociome.R through Rscript.
# Requires R, sociome, tidycensus, and a Census API key.
USE_SOCIOME_ADI=0
CENSUS_API_KEY=
